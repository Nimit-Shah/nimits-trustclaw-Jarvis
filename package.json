{
  "name": "nimits-jarvis",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A self-hostable personal AI agent with vector memory, Composio tools, and Telegram.",
  "license": "MIT",
  "author": "Composio <sarah@composio.dev>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ComposioHQ/nimits-jarvis.git"
  },
  "homepage": "https://github.com/ComposioHQ/nimits-jarvis#readme",
  "bugs": "https://github.com/ComposioHQ/nimits-jarvis/issues",
  "keywords": [
    "ai-agent",
    "composio",
    "nextjs",
    "trpc",
    "self-hosted",
    "telegram-bot",
    "vercel"
  ],
  "scripts": {
    "build": "prisma generate && prisma db push --accept-data-loss && next build",
    "build:local": "NODE_ENV=production next build",
    "check": "next lint && tsc --noEmit",
    "dev": "next dev --turbo",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "auth:generate": "npx @better-auth/cli generate",
    "cli:deploy": "cd cli && pnpm install --silent && pnpm exec tsx src/bin.ts deploy",
    "preview": "next build && next start",
    "start": "next start",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.87",
    "@composio/core": "^0.6.3",
    "@composio/vercel": "^0.6.3",
    "@hookform/resolvers": "^5.4.0",
    "@huggingface/transformers": "^4.2.0",
    "@openrouter/ai-sdk-provider": "^2.10.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-roving-focus": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-toast": "^1.2.19",
    "@t3-oss/env-nextjs": "^0.12.0",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-virtual": "^3.13.18",
    "@trpc/client": "^11.18.0",
    "@trpc/react-query": "^11.18.0",
    "@trpc/server": "^11.18.0",
    "ai": "^6.0.78",
    "ai-sdk-ollama": "^3.8.7",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "croner": "^10.0.1",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.42.2",
    "ioredis": "^5.11.1",
    "js-yaml": "^5.2.1",
    "lucide-react": "^0.563.0",
    "moment": "^2.30.1",
    "moment-timezone": "^0.6.0",
    "next": "^15.5.18",
    "next-themes": "^0.4.6",
    "pg": "^8.18.0",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.12.2",
    "react-virtuoso": "^4.18.10",
    "remark-gfm": "^4.0.1",
    "resumable-stream": "^2.2.12",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@next/eslint-plugin-next": "^16.2.9",
    "@tailwindcss/postcss": "^4.0.15",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv": "^17.2.4",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.19",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "postcss": "^8.5.19",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "prisma": "^7.8.0",
    "shadcn": "^3.8.4",
    "tailwindcss": "^4.3.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.27.0"
  },
  "ct3aMetadata": {
    "initVersion": "7.40.0"
  },
  "engines": {
    "node": ">=22.12.0 <23 || >=24.0.0"
  },
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "prisma",
      "@prisma/client",
      "sharp",
      "unrs-resolver"
    ]
  }
}
